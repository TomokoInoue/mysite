---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import LeftContent from '../components/LeftContent.astro';
import RightContent from '../components/RightContent.astro';
import Drawer from '../components/Drawer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import '../styles/style.scss';

import { getCollection } from 'astro:content';
const posts = await getCollection('posts');
// 新しい順
posts.sort((a, b) => 
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
// 最初の5件だけ
const firstPosts = posts.slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="wrapper" data-site>
			<Header />
			<LeftContent />
			<div class="stage pushable">
				<main class="contents">
					<RightContent posts={firstPosts} />
				</main>
			</div>
			<Drawer />
			<div class="frame" aria-hidden="true">
				<span class="cornerLeftTop"></span>
				<span class="cornerRightTop"></span>
				<span class="cornerLeftBottom"></span>
				<span class="cornerRightBottom"></span>
			</div>
		</div>
		<script>
			import "../scripts/menu.js";
			</script>
	</body>
</html>
