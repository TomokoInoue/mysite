     <img src={`${homeUrl}assets/common/share_icon02.svg`} alt="instagram" width="17" height="17">
    </a>
   </li>
   <li>
    <a href="https://note.com/jonson0521" target="_blank" rel="noopener noreferrer">
     <img src={`${homeUrl}assets/common/share_icon03.svg`} alt="note" width="17" height="17"></a>
   </li>
   <li>
    <a href="mailto:tomo.inoue0521@gmail.com">
     <img src={`${homeUrl}assets/common/share_icon05.svg`} alt="E-mail" width="18" height="17">
    </a>
   </li>
  </ul>
  <div class="friends">
   <p class="friends__ttl langText" data-lang="ko">함께 만드는 친구들</p>
