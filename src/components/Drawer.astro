     <img src={`${homeUrl}assets/about/friends_img03.jpg`} alt="friend's photo" width="10" height="10">
     <p class="friends__name">Emi Hatanaka<span>Graphic Designer</span></p>
    </li>
    <li class="friends__card">
     <img src={`${homeUrl}assets/about/friends_img05.jpg`} alt="friend's photo" width="10" height="10">
     <p class="friends__name">Minmin<span>3D designer</span></p>
    </li>
