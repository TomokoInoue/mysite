    </a>
   </li>
  </ul>
  <div class="friends">
   <p class="friends__ttl langText" data-lang="ko">창작 친구들</p>
   <p class="friends__ttl langText isHidden" data-lang="ja">クリエイター仲間</p>
   <ul class="friends__list">
    <li class="friends__card">
     <img src={`${homeUrl}assets/about/friends_img01.jpg`} alt="friend's photo" width="10" height="10">
     <p class="friends__name">Roxanne<span>Graphic Designer</span></p>
    </li>
    <li class="friends__card">
     <img src={`${homeUrl}assets/about/friends_img02.jpg`} alt="friend's photo" width="10" height="10">
     <p class="friends__name">Jung kyungwan<span>Interpreter</span></p>
    </li>
    <li class="friends__card">
     <img src={`${homeUrl}assets/about/friends_img03.jpg`} alt="friend's photo" width="10" height="10">
     <p class="friends__name">Michael jbn<span>Web Developer</span></p>
