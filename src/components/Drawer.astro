    <li class="friends__card">
     <img src={`${homeUrl}assets/about/friends_img04.jpg`} alt="friend's photo" width="10" height="10">
     <p class="friends__name">Koichi Imamura<span>Producer</span></p>
    </li>
   </ul>
  </div>
 </div>
 <button class="drawer__close" type="button" aria-label="Close menu" data-menu-close></button>
</aside>
